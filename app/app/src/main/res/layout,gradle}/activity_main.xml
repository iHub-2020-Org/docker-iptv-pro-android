<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".MainActivity">

    <!-- Video SurfaceView - Full Screen -->
    <SurfaceView
        android:id="@+id/video_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Bottom Info Bar - Hidden by default -->
    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_info_bar"
        android:orientation="horizontal"
        android:padding="@dimen/info_bar_padding"
        android:visibility="gone"
        android:focusable="true"
        android:focusableInTouchMode="true">

        <TextView
            android:id="@+id/channel_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_info"
            android:maxLines="1"
            android:ellipsize="end"
            android:focusable="true" />

        <TextView
            android:id="@+id/resolution_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_medium"
            android:background="@drawable/bg_resolution_badge"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_small"
            android:paddingHorizontal="@dimen/spacing_small"
            android:paddingVertical="@dimen/spacing_xsmall"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
